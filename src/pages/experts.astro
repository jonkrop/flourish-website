    }

    .pull-quote__inner footer {
      line-height: 1.5;
    }

    @keyframes panelSlideIn {
      from {
        opacity: 0;
        max-height: 0;
        padding: 0;
      }
      to {
        opacity: 1;
        max-height: 900px;
        padding: var(--space-lg);
      }
    }
  }
</style>

<script>
  // ===== Card expand/collapse =====
  const cards = document.querySelectorAll('.expert-card');
  const panels = document.querySelectorAll('.expert-detail');
  const grid = document.querySelector('.experts__grid');

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const expertId = card.dataset.expert;
      const panel = document.querySelector(`.expert-detail[data-for="${expertId}"]`);
      if (!panel) return;

      const isOpen = panel.classList.contains('open');

      // Close all panels first
      panels.forEach(p => {
        p.classList.remove('open');
        p.style.display = 'none';
        p.setAttribute('aria-hidden', 'true');
      });
      cards.forEach(c => {
        c.classList.remove('expert-card--active');
        c.setAttribute('aria-expanded', 'false');
      });

      // Open the clicked one (unless it was already open)
      if (!isOpen) {
        // Force reflow so card positions recalculate after closing panels
        grid.offsetHeight;

        // Find all cards in the same visual row (same offsetTop)
        const cardTop = card.offsetTop;
        const rowCards = [...cards].filter(c => Math.abs(c.offsetTop - cardTop) < 10);
        const lastCardInRow = rowCards[rowCards.length - 1];

        // Move panel in DOM to after the last card's detail panel in this row
        // This ensures the panel opens between rows, not mid-row
        const lastCardSibling = lastCardInRow.nextElementSibling;
        const insertAfter = (lastCardSibling && lastCardSibling.classList.contains('expert-detail'))
          ? lastCardSibling
          : lastCardInRow;
        insertAfter.after(panel);

        panel.style.display = 'block';
        // Force reflow for animation
        panel.offsetHeight;
        panel.classList.add('open');
        panel.setAttribute('aria-hidden', 'false');
        card.classList.add('expert-card--active');
        card.setAttribute('aria-expanded', 'true');

        // Smooth scroll so card + panel are visible
        setTimeout(() => {
          card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      }
    });

    // Keyboard support
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        card.click();
      }
    });
  });

  // Close buttons
  document.querySelectorAll('.expert-detail__close').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const panel = btn.closest('.expert-detail');
      if (!panel) return;
      const expertId = panel.dataset.for;
      const card = document.querySelector(`.expert-card[data-expert="${expertId}"]`);

      panel.classList.remove('open');
      panel.setAttribute('aria-hidden', 'true');
      if (card) {
        card.classList.remove('expert-card--active');
        card.setAttribute('aria-expanded', 'false');
      }

      setTimeout(() => {
        panel.style.display = 'none';
        if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 400);
    });
  });

  // ===== Mobile menu toggle =====
  const toggle = document.querySelector('.header__mobile-toggle');
  const mobileNav = document.querySelector('.mobile-nav');

  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      mobileNav.setAttribute('aria-hidden', String(!isOpen));
    });
  }

  // ===== Header scroll effect =====
  const header = document.querySelector('.header');

  function updateHeader() {
    if (window.scrollY > 50) {
      header?.classList.add('header--scrolled');
    } else {
      header?.classList.remove('header--scrolled');
    }
  }

  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
