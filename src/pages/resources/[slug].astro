---
import { getCollection } from 'astro:content';
import ResourceLayout from '../../layouts/ResourceLayout.astro';
import ResourceSection from '../../components/ResourceSection.astro';
import SpeakerBio from '../../components/SpeakerBio.astro';

export async function getStaticPaths() {
  const topics = await getCollection('topics');

  return topics.map((topic) => ({
    params: { slug: topic.data.slug || topic.slug },
    props: { entry: topic },
  }));
}

const { entry } = Astro.props;
const allClients = await getCollection('clients');
const allExperts = await getCollection('experts');

const topicSlug = entry.data.slug || entry.slug;

// Build client lookup for back-link text on topic pages
const clientLookup: Record<string, string> = {};
for (const c of allClients) {
  clientLookup[c.data.slug || c.slug] = c.data.name;
}

const topicData = entry.data as { title: string; subtitle?: string; intro?: string; defaultPresenters?: string[]; sections: any[] };
const pageTitle = topicData.title;

// Resolve default presenters from the topic itself
const defaultPresenterEntries = (topicData.defaultPresenters || [])
  .map((slug) => allExperts.find((e) => (e.data.slug || e.slug) === slug))
  .filter((e): e is typeof allExperts[number] => !!e)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Build per-client presenter map for this topic
// { clientSlug: expertEntry[] }
// Clients with explicit assignments get their own block;
// clients without explicit assignments fall back to defaultPresenters
const clientPresenterMap: Record<string, typeof allExperts> = {};
for (const client of allClients) {
  const cSlug = client.data.slug || client.slug;
  const clientTopics = (client.data as any).topics as string[] | undefined;
  if (!clientTopics?.includes(topicSlug)) continue;

  const presentersData = (client.data as any).presenters as Array<{ topic: string; speakers: string[] }> | undefined;
  const match = presentersData?.find((p) => p.topic === topicSlug);

  if (match?.speakers.length) {
    // Explicit assignment
    const resolved = match.speakers
      .map((slug) => allExperts.find((e) => (e.data.slug || e.slug) === slug))
      .filter((e): e is typeof allExperts[number] => !!e)
      .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
    if (resolved.length) {
      clientPresenterMap[cSlug] = resolved;
    }
  } else if (defaultPresenterEntries.length) {
    // Fall back to topic defaults
    clientPresenterMap[cSlug] = defaultPresenterEntries;
  }
}
const hasAnyPresenters = Object.keys(clientPresenterMap).length > 0;
---

<ResourceLayout title={pageTitle}>
  <div class="resource-page">
    <div class="resource-page__hero">
      <div class="hero__bg">
        <img src="/images/hero-foliage-light.webp" alt="" class="hero__bg-img" loading="eager" />
      </div>
      <div class="hero__border" aria-hidden="true"></div>
      <div class="hero__fg" aria-hidden="true">
        <img src="/images/foliage-overlay-light.webp" alt="" class="hero__bg-img" />
      </div>
      <div class="container hero__content">
        <div id="back-link-container" class="resource-page__back-wrap" style="display: none;">
          <a id="back-link" href="#" class="resource-page__back">
            <span class="resource-page__back-arrow">&#8592;</span>
            <span id="back-link-text">Back to Resources</span>
          </a>
        </div>
        <h1 class="resource-page__title">{topicData.title}</h1>
        {topicData.subtitle && (
          <p class="resource-page__subtitle">
            <span class="accent">{topicData.subtitle}</span>
          </p>
        )}
        {topicData.intro && (
          <p class="resource-page__intro">{topicData.intro}</p>
        )}
      </div>
    </div>
    <div class="resource-page__content section">
      <div class="container container--narrow">
        <div class="resource-page__sections">
          {topicData.sections.map((section: any) => (
            <ResourceSection
              title={section.title}
              collapsed={section.collapsed}
              items={section.items}
            />
          ))}
        </div>
        {hasAnyPresenters && Object.entries(clientPresenterMap).map(([cSlug, experts]) => (
          <div class="presenters-section" data-presenters-client={cSlug} style="display: none;">
            <h3 class="presenters-section__heading">Your Presenters</h3>
            <div class="presenters-section__list">
              {experts.map((expert) => (
                <SpeakerBio
                  name={expert.data.name}
                  role={expert.data.role}
                  photo={expert.data.photo}
                  bio={expert.data.bio}
                  credentials={expert.data.credentials}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Client lookup data for back-link and presenters JS -->
  <script define:vars={{ clientLookup }}>
    // Handle ?client= param for back link and presenters
    const params = new URLSearchParams(window.location.search);
    const clientSlug = params.get('client');
    if (clientSlug && clientLookup[clientSlug]) {
      const container = document.getElementById('back-link-container');
      const link = document.getElementById('back-link');
      const text = document.getElementById('back-link-text');
      if (container && link && text) {
        container.style.display = 'block';
        link.setAttribute('href', `/${clientSlug}`);
        text.textContent = `Back to ${clientLookup[clientSlug]} Resources`;
      }

      // Show the matching presenters block
      const presenterBlock = document.querySelector(`[data-presenters-client="${clientSlug}"]`);
      if (presenterBlock) {
        presenterBlock.style.display = '';
      }
    }

    // Collapsible sections
    document.querySelectorAll('.resource-section__header').forEach((btn) => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!expanded));
        const body = btn.nextElementSibling;
        if (body) {
          if (expanded) {
            body.style.display = 'none';
          } else {
            body.style.display = '';
          }
        }
      });
    });
  </script>
</ResourceLayout>

<style>
  /* ---- Hero (foliage, matching experts page) ---- */
  .resource-page__hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 35% 45%, rgba(5, 5, 5, 0.5) 0%, transparent 70%),
      linear-gradient(to bottom, rgba(5, 5, 5, 0.25) 0%, rgba(5, 5, 5, 0.05) 40%, rgba(5, 5, 5, 0.4) 100%);
    z-index: 1;
  }

  .hero__border {
    position: absolute;
    top: 90px;
    left: 3.5%;
    right: 3.5%;
    bottom: 5%;
    border: 2px solid var(--orange);
    z-index: 2;
    pointer-events: none;
  }

  .hero__fg {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    clip-path: polygon(3% 72%, 32% 72%, 32% 100%, 3% 100%);
  }

  .resource-page__hero .container {
    max-width: none;
    margin-inline: 0;
    padding-left: max(7.5%, 4rem);
    padding-right: max(7.5%, 4rem);
  }

  .hero__content {
    position: relative;
    z-index: 4;
    padding-top: 8rem;
    padding-bottom: max(7%, 4.5rem);
  }

  .resource-page__eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: var(--space-md);
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }

  .resource-page__title {
    font-size: var(--text-2xl);
    font-weight: 300;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--cream);
    margin-bottom: var(--space-sm);
    max-width: 28ch;
    opacity: 0;
    animation: fadeUp 0.8s 0.4s forwards;
  }

  .resource-page__subtitle {
    font-size: var(--text-xl);
    color: var(--cream);
    margin-bottom: var(--space-sm);
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }

  .resource-page__subtitle .accent {
    color: inherit;
  }

  .resource-page__intro {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 58ch;
    line-height: 1.7;
    opacity: 0;
    animation: fadeUp 0.8s 0.6s forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- Back link ---- */
  .resource-page__back-wrap {
    margin-bottom: var(--space-md);
  }

  .resource-page__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .resource-page__back:hover {
    color: var(--orange);
  }

  .resource-page__back-arrow {
    font-size: 1.1rem;
    transition: transform var(--transition-base);
  }

  .resource-page__back:hover .resource-page__back-arrow {
    transform: translateX(-3px);
  }

  /* ---- Card grid ---- */
  .resource-page__grid-section {
    padding-block: var(--space-lg) var(--space-xl);
  }

  .resource-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  /* ---- Content sections ---- */
  .resource-page__content {
    padding-block: var(--space-lg) var(--space-xl);
  }

  .resource-page__sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* ---- Presenters ---- */
  .presenters-section {
    margin-top: var(--space-xl);
  }

  .presenters-section__heading {
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--cream);
    margin-bottom: var(--space-md);
  }

  .presenters-section__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  @media (max-width: 768px) {
    .resource-page__hero {
      min-height: 50vh;
    }

    .hero__border {
      top: 70px;
      left: 3%;
      right: 3%;
      bottom: 3%;
    }

    .hero__fg {
      display: none;
    }

    .resource-page__hero .container {
      padding-inline: max(5%, 1.5rem);
    }

    .hero__content {
      padding-top: 5.5rem;
      padding-bottom: 3rem;
    }

    .resource-page__title {
      max-width: 100%;
    }

    .resource-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
