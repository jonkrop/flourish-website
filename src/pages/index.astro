---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Flourish Legal Well-Being">

  <!-- ===== HEADER / NAV ===== -->
  <header class="header">
    <div class="container header__inner">
      <a href="/" class="header__logo">
        <img src="/images/logo-orange-alt.png" alt="Flourish Legal Well-Being" width="180" height="48" />
      </a>
      <nav class="header__nav">
        <a href="#topics" class="header__link">Topics</a>
        <a href="#how-it-works" class="header__link">How It Works</a>
        <a href="/experts" class="header__link">Our Experts</a>
        <a href="/book" class="btn btn--primary">Book a Call</a>
      </nav>
      <button class="header__mobile-toggle" aria-label="Open menu" aria-expanded="false">
        <span></span>
        <span></span>
      </button>
    </div>
  </header>

  <!-- Mobile nav overlay -->
  <div class="mobile-nav" aria-hidden="true">
    <nav class="mobile-nav__inner">
      <a href="#topics" class="mobile-nav__link">Topics</a>
      <a href="#how-it-works" class="mobile-nav__link">How It Works</a>
      <a href="/experts" class="mobile-nav__link">Our Experts</a>
      <a href="/book" class="btn btn--primary" style="width:100%;justify-content:center;">Book a Call</a>
    </nav>
  </div>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <!-- Layer 0: dark foliage background -->
    <div class="hero__bg">
      <img src="/images/hero-foliage-light.webp" alt="" class="hero__bg-img" loading="eager" />
    </div>
    <!-- Layer 1: CSS orange border (sharp, responsive) -->
    <div class="hero__border" aria-hidden="true"></div>
    <!-- Layer 2: foreground foliage (same leaves, white removed for transparency - overlaps border for 3D) -->
    <div class="hero__fg" aria-hidden="true">
      <img src="/images/foliage-overlay-light.webp" alt="" class="hero__bg-img" />
    </div>
    <!-- Layer 3: content -->
    <div class="container hero__content">
      <p class="hero__eyebrow">Trusted by more than half the AmLaw 100</p>
      <h1 class="hero__title">
        Well-being that <em class="accent">actually lands</em> for law firms.
      </h1>
      <p class="hero__subtitle">
        Interactive workshops, led by world-class experts, with turnkey delivery.
      </p>
      <div class="hero__actions">
        <a href="/book" class="btn btn--primary">Book a Discovery Call</a>
      </div>
    </div>
  </section>

  <!-- ===== LOGO WALL ===== -->
  <section class="section logos">
    <div class="container">
      <div class="logos__block reveal">
        <p class="logos__label">Trusted by</p>
        <div class="logos__row">
          <img class="logos__img" src="/logos/ao-shearman.png" alt="A&O Shearman" />
          <img class="logos__img" src="/logos/akin-gump.png" alt="Akin Gump" />
          <img class="logos__img" src="/logos/autodesk.png" alt="Autodesk" />
          <img class="logos__img" src="/logos/baker-mckenzie.png" alt="Baker McKenzie" />
          <img class="logos__img" src="/logos/cleary-gottlieb.png" alt="Cleary Gottlieb" />
          <img class="logos__img" src="/logos/cooley.png" alt="Cooley" />
          <img class="logos__img" src="/logos/covington.png" alt="Covington" />
          <img class="logos__img" src="/logos/cozen-oconnor.png" alt="Cozen O'Connor" />
          <img class="logos__img" src="/logos/crowell-moring.png" alt="Crowell & Moring" />
          <img class="logos__img" src="/logos/davis-polk.png" alt="Davis Polk" />
          <img class="logos__img" src="/logos/debevoise.png" alt="Debevoise & Plimpton" />
          <img class="logos__img" src="/logos/dla-piper.png" alt="DLA Piper" />
          <img class="logos__img" src="/logos/finnegan.png" alt="Finnegan" />
          <img class="logos__img" src="/logos/foley-lardner.png" alt="Foley & Lardner" />
          <img class="logos__img" src="/logos/fox-rothschild.png" alt="Fox Rothschild" />
          <img class="logos__img" src="/logos/freshfields.png" alt="Freshfields" />
          <img class="logos__img" src="/logos/fried-frank.png" alt="Fried Frank" />
          <img class="logos__img" src="/logos/general-electric.png" alt="General Electric" />
          <img class="logos__img" src="/logos/gibson-dunn.png" alt="Gibson Dunn" />
          <img class="logos__img" src="/logos/greenberg-traurig.png" alt="Greenberg Traurig" />
          <img class="logos__img" src="/logos/harvard-law.png" alt="Harvard Law School" />
          <img class="logos__img" src="/logos/hogan-lovells.png" alt="Hogan Lovells" />
          <img class="logos__img" src="/logos/jackson-lewis.png" alt="Jackson Lewis" />
          <img class="logos__img" src="/logos/kl-gates.png" alt="K&L Gates" />
          <img class="logos__img" src="/logos/kirkland-ellis.png" alt="Kirkland & Ellis" />
          <img class="logos__img" src="/logos/mcdermott.png" alt="McDermott Will & Schulte" />
          <img class="logos__img" src="/logos/milbank.png" alt="Milbank" />
          <img class="logos__img" src="/logos/morrison-foerster.png" alt="Morrison Foerster" />
          <img class="logos__img" src="/logos/nbcuniversal.png" alt="NBCUniversal" />
          <img class="logos__img" src="/logos/nyu-law.png" alt="NYU Law" />
          <img class="logos__img" src="/logos/omelveny.png" alt="O'Melveny" />
          <img class="logos__img" src="/logos/orrick.png" alt="Orrick" />
          <img class="logos__img" src="/logos/paul-weiss.png" alt="Paul Weiss" />
          <img class="logos__img" src="/logos/penn-law.png" alt="Penn Law" />
          <img class="logos__img" src="/logos/perkins-coie.png" alt="Perkins Coie" />
          <img class="logos__img" src="/logos/pillsbury.png" alt="Pillsbury" />
          <img class="logos__img" src="/logos/proskauer.png" alt="Proskauer" />
          <img class="logos__img" src="/logos/reed-smith.png" alt="Reed Smith" />
          <img class="logos__img" src="/logos/ropes-gray.png" alt="Ropes & Gray" />
          <img class="logos__img" src="/logos/sidley.png" alt="Sidley" />
          <img class="logos__img" src="/logos/simpson-thacher.png" alt="Simpson Thacher" />
          <img class="logos__img" src="/logos/stanford-law.png" alt="Stanford Law School" />
          <img class="logos__img" src="/logos/sullivan-cromwell.png" alt="Sullivan & Cromwell" />
          <img class="logos__img" src="/logos/venable.png" alt="Venable" />
          <img class="logos__img" src="/logos/white-case.png" alt="White & Case" />
          <img class="logos__img" src="/logos/wilmerhale.png" alt="WilmerHale" />
          <img class="logos__img" src="/logos/wilson-sonsini.png" alt="Wilson Sonsini" />
          <img class="logos__img" src="/logos/winston-strawn.png" alt="Winston & Strawn" />
          <img class="logos__img" src="/logos/yale-law.png" alt="Yale Law School" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROBLEM ===== -->
  <section class="section problem grain">
    <div class="container container--narrow">
      <p class="problem__lead reveal">
        You already know well-being matters. You don't need to be convinced - you need it to <em class="accent">happen.</em>
      </p>
      <div class="problem__list reveal reveal-delay-1">
        <p>Half the "wellness" content out there feels like it was written for a yoga retreat, not a litigation department.</p>
        <p>Attendance is mediocre.</p>
        <p>And every program means more work for you.</p>
        <p>What if your well-being programming just <em class="accent">ran itself?</em></p>
      </div>
    </div>
  </section>

  <!-- Inline quote: validates the turnkey pain point -->
  <div class="pull-quote reveal">
    <div class="container">
      <blockquote class="pull-quote__inner">
        <p>"It required minimal input and effort from my team but was very effective."</p>
        <footer>Director of Professional Development & Training, <span class="text-muted">AmLaw 50 Firm</span></footer>
      </blockquote>
    </div>
  </div>

  <!-- ===== WORKSHOP PHOTO ===== -->
  <div class="photo-break reveal">
    <img src="/images/workshop-room-clean.webp" alt="Jon Krop leading a well-being workshop at a law firm" class="photo-break__img" loading="lazy" />
  </div>

  <!-- ===== SOLUTION / DIFFERENTIATORS ===== -->
  <section class="section diffs">
    <div class="container">
      <div class="diffs__header reveal">
        <h2>A smarter way to do <em class="accent">well-being.</em></h2>
      </div>

      <div class="diffs__grid">
        <div class="diffs__card reveal">
          <div class="diffs__card-accent"></div>
          <span class="diffs__number">01</span>
          <h3>We handle <em class="accent">everything.</em></h3>
          <p>Pre-written emails, CLE applications, internal promotion, logistics, follow-up. You approve the plan. We execute it.</p>
          <div class="diffs__rating diffs__rating--96">
            <span class="diffs__rating-number">9.6<span class="diffs__rating-of">/10</span></span>
            <span class="diffs__rating-label">AVG. CLIENT<br/>RATING</span>
          </div>
        </div>

        <div class="diffs__card reveal reveal-delay-1">
          <div class="diffs__card-accent"></div>
          <span class="diffs__number">02</span>
          <h3>Every topic, <em class="accent">covered.</em></h3>
          <p>Stress, sleep, resilience, communication, burnout, nutrition, financial wellness - all from one team that already knows your firm.</p>
        </div>

        <div class="diffs__card diffs__card--expert reveal reveal-delay-2">
          <div class="diffs__card-accent"></div>
          <div class="diffs__card-body">
            <span class="diffs__number">03</span>
            <h3>Experts your lawyers <em class="accent">will take seriously.</em></h3>
            <p>Harvard, Yale, Columbia, Oxford - and most are lawyers themselves. The eye-rolls stop before they start.</p>
          </div>
          <div class="diffs__card-photo">
            <img src="/images/jon-headshot-botanical.webp" alt="Jon Krop, Founder" loading="lazy" />
            <span class="diffs__card-caption">Jon Krop, Founder</span>
          </div>
        </div>

        <div class="diffs__card reveal reveal-delay-3">
          <div class="diffs__card-accent"></div>
          <span class="diffs__number">04</span>
          <h3>Interactive, <em class="accent">not interminable.</em></h3>
          <p>Live exercises, real tools, and conversations people actually remember on Monday.</p>
          <div class="diffs__rating">
            <span class="diffs__rating-number">9.2<span class="diffs__rating-of">/10</span></span>
            <span class="diffs__rating-label">AVG. AUDIENCE<br/>RATING</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inline quote: validates expert credibility + engagement -->
  <div class="pull-quote pull-quote--dark reveal">
    <div class="container">
      <blockquote class="pull-quote__inner">
        <p>"Completely engaging, on point, and quite entertaining."</p>
        <footer>Adrian Rae Leipsic, Partner, <span class="text-muted">Cleary Gottlieb</span></footer>
      </blockquote>
    </div>
  </div>

  <!-- ===== WHAT WE COVER ===== -->
  <section id="topics" class="section topics grain">
    <div class="container">
      <div class="topics__header reveal">
        <h2>Every dimension of <em class="accent">well-being.</em></h2>
        <p class="topics__subtitle text-muted">One trusted partner covering everything your people need.</p>
      </div>

      <div class="topics__grid">
        <div class="topics__item reveal">
          <span class="topics__icon">&#9670;</span>
          <h4>Stress & Resilience</h4>
          <p>Concrete tools for staying sharp under pressure - skills lawyers can use the same day.</p>
        </div>
        <div class="topics__item reveal reveal-delay-1">
          <span class="topics__icon">&#9670;</span>
          <h4>Burnout Prevention</h4>
          <p>Recognizing the signs early and building sustainable habits before the damage is done.</p>
        </div>
        <div class="topics__item reveal reveal-delay-2">
          <span class="topics__icon">&#9670;</span>
          <h4>Sleep</h4>
          <p>Evidence-based strategies for the sleep-deprived professional. Our most requested topic, for obvious reasons.</p>
        </div>
        <div class="topics__item reveal reveal-delay-3">
          <span class="topics__icon">&#9670;</span>
          <h4>Communication & Conflict</h4>
          <p>Navigating difficult conversations, giving feedback, and building stronger team dynamics.</p>
        </div>
        <div class="topics__item reveal">
          <span class="topics__icon">&#9670;</span>
          <h4>Mindfulness & Focus</h4>
          <p>Practical attention training for the perpetually distracted. No incense required.</p>
        </div>
        <div class="topics__item reveal reveal-delay-1">
          <span class="topics__icon">&#9670;</span>
          <h4>Nutrition & Energy</h4>
          <p>Fueling high performance without fad diets - real science for demanding schedules.</p>
        </div>
        <div class="topics__item reveal reveal-delay-2">
          <span class="topics__icon">&#9670;</span>
          <h4>Financial Well-Being</h4>
          <p>Smart money management for high earners - from associates managing debt to partners planning ahead.</p>
        </div>
        <div class="topics__item reveal reveal-delay-3">
          <span class="topics__icon">&#9670;</span>
          <h4>And More</h4>
          <p>Work-life balance, emotional intelligence, substance use, parenting, caregiving - whatever your firm needs next.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Inline quote: validates content quality -->
  <div class="pull-quote reveal">
    <div class="container">
      <blockquote class="pull-quote__inner">
        <p>"The content is excellent, and the Flourish team is at the forefront of some of the most challenging topics that associates have to navigate."</p>
        <footer>Professional Development Manager, <span class="text-muted">AmLaw 50 Firm</span></footer>
      </blockquote>
    </div>
  </div>

  <!-- ===== GUARANTEE ===== -->
  <section class="section guarantee grain">
    <div class="container">
      <div class="guarantee__inner reveal">
        <div class="bordered-frame">
          <p class="guarantee__eyebrow">Our guarantee</p>
          <h2>100% satisfied or <em class="accent">100% refunded.</em></h2>
          <p class="guarantee__body">
            If you're not happy with any Flourish program, we refund the full fee. No questions asked. We've never had to pay.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="section how-it-works">
    <div class="container">
      <div class="how__header reveal">
        <h2>What working with us <em class="accent">looks like.</em></h2>
      </div>

      <div class="how__steps">
        <div class="how__step reveal">
          <span class="how__step-number">1</span>
          <div class="how__step-content">
            <h4>Discovery call</h4>
            <p>A 30-minute conversation about your firm's culture and goals.</p>
          </div>
        </div>
        <div class="how__step reveal reveal-delay-1">
          <span class="how__step-number">2</span>
          <div class="how__step-content">
            <h4>Custom program design</h4>
            <p>We propose a tailored set of workshops matched to your firm's needs and calendar. You shape it until it's right.</p>
          </div>
        </div>
        <div class="how__step reveal reveal-delay-2">
          <span class="how__step-number">3</span>
          <div class="how__step-content">
            <h4>We take it from here</h4>
            <p>Promotion, logistics, CLE, delivery, follow-up. You get periodic updates and rave reviews. That's it.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inline quote: validates ease of process -->
  <div class="pull-quote pull-quote--dark reveal">
    <div class="container">
      <blockquote class="pull-quote__inner">
        <p>"You made it very easy for us, down to a script for messaging."</p>
        <footer>Chief Talent Officer, <span class="text-muted">AmLaw 100 Firm</span></footer>
      </blockquote>
    </div>
  </div>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section testimonials grain">
    <div class="container">
      <div class="testimonials__header reveal">
        <h2>What our clients <em class="accent">say.</em></h2>
      </div>
      <div class="testimonials__grid">
        <blockquote class="testimonial reveal">
          <p class="testimonial__quote">"I've been doing programming for law firms for 25 years, and I will say that Jon soared to the top of my list of excellent presenters."</p>
          <footer class="testimonial__attr">
            <span class="testimonial__name">Professional Development Director</span>
            <span class="testimonial__firm">AmLaw 50 Firm</span>
          </footer>
        </blockquote>
        <blockquote class="testimonial reveal reveal-delay-1">
          <p class="testimonial__quote">"Attendance was incredible, with 177 participants at one point and over 100 staying for the optional Q&A. Significantly, 99 attorneys joined, which is a huge success for us."</p>
          <footer class="testimonial__attr">
            <span class="testimonial__name">Professional Development Director</span>
            <span class="testimonial__firm">AmLaw 50 Firm</span>
          </footer>
        </blockquote>
        <blockquote class="testimonial reveal reveal-delay-2">
          <p class="testimonial__quote">"Months later, I'm still hearing from lawyers and staff about how much they loved the program."</p>
          <footer class="testimonial__attr">
            <span class="testimonial__name">Jennifer Mencarini, Director of Cultural Engagement</span>
            <span class="testimonial__firm">Fox Rothschild</span>
          </footer>
        </blockquote>
        <blockquote class="testimonial reveal reveal-delay-3">
          <p class="testimonial__quote">"The speakers are all top-notch. The support leading up to the event is white glove with sample emails, which makes our job so much easier."</p>
          <footer class="testimonial__attr">
            <span class="testimonial__name">Chief Human Resources Officer</span>
            <span class="testimonial__firm">AmLaw 200 Firm</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ===== FINAL CTA ===== -->
  <section class="section cta-final">
    <div class="container">
      <div class="cta-final__layout reveal">
        <div class="cta-final__photo">
          <img src="/images/jon-speaking.webp" alt="Jon Krop speaking at NYU" loading="lazy" />
        </div>
        <div class="cta-final__inner">
          <h2>Ready to make well-being <em class="accent">effortless?</em></h2>
          <p>Book a 30-minute discovery call. We'll listen, learn about your firm, and show you what's possible.</p>
          <a href="/book" class="btn btn--primary">Book a Discovery Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="container footer__inner">
      <div class="footer__brand">
        <img src="/images/logo-orange-alt.png" alt="Flourish" width="140" height="37" />
        <p class="text-sm text-muted">Well-being that works for law firms.</p>
      </div>
      <div class="footer__links">
        <a href="/experts">Our Experts</a>
        <a href="/book">Book a Call</a>
      </div>
      <div class="footer__legal text-sm text-muted">
        &copy; {new Date().getFullYear()} Flourish Legal Well-Being. All rights reserved.
      </div>
    </div>
  </footer>

</BaseLayout>

<style>
  /* ===================================================================
     HEADER
     =================================================================== */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 0;
    transition: background var(--transition-base), backdrop-filter var(--transition-base);
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .header--scrolled {
    background: rgba(9, 26, 24, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header .container {
    max-width: none;
    margin-inline: 0;
    padding-inline: max(3.5%, 1.5rem);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__logo img {
    height: 36px;
    width: auto;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .header__link {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    opacity: 0.8;
    transition: opacity var(--transition-fast), color var(--transition-fast);
  }

  .header__link:hover {
    opacity: 1;
    color: var(--orange);
  }

  .header__mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--cream);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(9, 26, 24, 0.97);
    backdrop-filter: blur(20px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
  }

  .mobile-nav.open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-nav__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: center;
    text-align: center;
  }

  .mobile-nav__link {
    font-size: var(--text-xl);
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .header__nav { display: none; }
    .header__mobile-toggle { display: flex; }
  }

  /* ===================================================================
     HERO
     =================================================================== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Layer 0: foliage background image */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dark vignette overlay for text readability */
  .hero__bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 35% 45%, rgba(5, 5, 5, 0.5) 0%, transparent 70%),
      linear-gradient(to bottom, rgba(5, 5, 5, 0.25) 0%, rgba(5, 5, 5, 0.05) 40%, rgba(5, 5, 5, 0.4) 100%);
    z-index: 1;
  }

  /* Layer 1: orange border */
  .hero__border {
    position: absolute;
    top: 90px;
    left: 3.5%;
    right: 3.5%;
    bottom: 5%;
    border: 2px solid var(--orange);
    z-index: 2;
    pointer-events: none;
  }

  /* Layer 2: foreground foliage overlay - same leaves as background, transparent bg.
     Hard clip to bottom-left area. Only the bottom border line gets overlapped, not the left. */
  .hero__fg {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    clip-path: polygon(5.5% 60%, 45% 60%, 45% 100%, 5.5% 100%);
  }

  /* Content sits inside the border - no max-width centering, just left-aligned with padding */
  .hero .container {
    max-width: none;
    margin-inline: 0;
    padding-left: max(7.5%, 4rem);
    padding-right: max(7.5%, 4rem);
  }

  .hero__content {
    position: relative;
    z-index: 4;
    padding-top: 8rem;
    padding-bottom: max(7%, 4.5rem);
  }

  .hero__eyebrow {
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: 0.12em;
